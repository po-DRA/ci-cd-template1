{
    "name": "CI/CD Template",

    // Pre-built Python image (GitHub caches this — fast startup).
    // Having a devcontainer.json at all stops GitHub's auto-Poetry-install.
    "image": "mcr.microsoft.com/devcontainers/python:3.12",

    "features": {
        // Installs Pixi; Pixi then provides Python + all project dependencies
        "ghcr.io/prefix-dev/devcontainer-features/pixi:1": {}
    },

    // onCreateCommand runs during prebuild (baked into the cached image).
    // postCreateCommand runs after the user gets the container — keep it fast.
    "onCreateCommand": "pixi install",

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "charliermarsh.ruff",
                "ms-python.mypy-type-checker"
            ],
            "settings": {
                "python.defaultInterpreterPath": "${workspaceFolder}/.pixi/envs/default/bin/python"
            }
        }
    }
}
